# Personal release-signing credentials. Copy this to keystore.properties and fill in.
# keystore.properties and *.jks are gitignored — never commit.
#
# Generate a keystore (one-time):
#   keytool -genkey -v -keystore flux-release.jks -alias flux \
#           -keyalg RSA -keysize 2048 -validity 36500
#
# Paths are resolved relative to the repo root.

storeFile=flux-release.jks
storePassword=your-store-password
keyAlias=flux
keyPassword=your-key-password
