<?xml version="1.0" encoding="utf-8"?>
<!--
    Release builds require HTTPS: cleartext is disabled here, and the URL
    normalizer rejects http:// input (allowHttp = BuildConfig.DEBUG). Debug
    builds override this file via src/debug/res/xml/network_security_config.xml,
    which permits cleartext and user-added CAs for local tinkering.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
